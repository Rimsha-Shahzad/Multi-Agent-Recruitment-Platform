# Copy this file to ".env" in the same folder and fill in what you have.
# Everything below is OPTIONAL. If a key is missing, the app automatically
# falls back to realistic MOCK data so the whole pipeline still runs.

# --- LLM ---
# If set, the Persona Agent and Content Agent will call GPT-4o for real.
# If left empty, a built-in mock generator is used instead.
OPENAI_API_KEY=

# --- Distribution channel APIs (all optional, mocked if missing) ---
LINKEDIN_API_KEY=
INDEED_API_KEY=
GOOGLE_JOBS_API_KEY=
HUBSPOT_API_KEY=

# --- Database ---
# Default: local SQLite file (zero setup).
# To use PostgreSQL instead, uncomment and edit the line below:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/recruitment
